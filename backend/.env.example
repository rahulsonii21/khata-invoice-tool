# Database (Supabase Postgres connection string - use the Session pooler variant)
# Get this from your Supabase project -> Connect button -> Session pooler
# Remember to URL-encode special characters in your password (@ becomes %40, etc.)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:your_encoded_password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Gemini API key for OCR (free tier) - get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase Storage - used for invoice images and backups in production.
# Leave these unset for local development (falls back to local disk automatically).
# SUPABASE_SERVICE_ROLE_KEY accepts either the legacy service_role JWT
# or the newer sb_secret_... key format - both work the same way here.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=invoice

# How many nightly backups to keep before old ones are deleted
BACKUP_RETENTION_COUNT=14
